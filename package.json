{
  "name": "lighthouse",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "npm --prefix server run dev",
    "dev:all": "concurrently -n ui,server -c cyan,yellow \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "remotion:studio": "remotion studio src/remotion/index.ts",
    "remotion:render": "remotion render src/remotion/index.ts ArchitectureWalkthrough out/architecture-walkthrough.mp4",
    "remotion:still": "remotion still src/remotion/index.ts ArchitectureWalkthrough out/architecture-walkthrough.png",
    "remotion:voiceover": "node scripts/generate-remotion-voiceover.mjs"
  },
  "dependencies": {
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xyflow/react": "^12.3.6",
    "elkjs": "^0.9.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^16.1.1",
    "remotion": "^4.0.481"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.481",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.3",
    "vite": "^5.4.10"
  }
}
